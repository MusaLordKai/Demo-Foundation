# Copy to .env for local (non-Docker) runs. docker-compose injects its own values.
DATABASE_URL="postgresql://caseproc:caseproc@localhost:5432/caseproc?schema=public"
JWT_SECRET="dev-only-change-me"
PORT=4000
UPLOAD_DIR="./uploads"
# Max attachment size in bytes (default 5 MB)
MAX_UPLOAD_BYTES=5242880
# Comma-separated allowlist of attachment mime types
ALLOWED_MIME="application/pdf,image/png,image/jpeg"
# Frontend origin allowed by CORS
CORS_ORIGIN="http://localhost:5173"

# --- Email notifications (stretch goal) ---
# Optional: leave MAIL_USER/MAIL_PASS blank to disable email (the app no-ops).
# For Gmail, MAIL_PASS must be an App Password (not your account password).
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@demofoundation.com"
MAIL_FROM_NAME="DEMO FOUNDATION"
